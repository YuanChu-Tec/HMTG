/**
 * 系统错误码枚举
 */
export enum ErrorCode {
  // 通用错误 (0-999)
  UNKNOWN = 0,
  UNKNOWN_ERROR = 1,
  INVALID_PARAMETER = 2,
  OPERATION_FAILED = 3,

  // 网络错误 (1000-1999)
  NETWORK_ERROR = 1000,
  NETWORK_TIMEOUT = 1001,
  NETWORK_DISCONNECTED = 1002,
  NETWORK_UNREACHABLE = 1003,

  // 认证错误 (2000-2999)
  AUTH_INVALID_CREDENTIALS = 2000,
  AUTH_TOKEN_EXPIRED = 2001,
  AUTH_TOKEN_INVALID = 2002,
  AUTH_USER_NOT_FOUND = 2003,
  AUTH_PERMISSION_DENIED = 2004,

  // 文件错误 (3000-3999)
  FILE_NOT_FOUND = 3000,
  FILE_READ_ERROR = 3001,
  FILE_WRITE_ERROR = 3002,
  FILE_DELETE_ERROR = 3003,

  // 数据库错误 (4000-4999)
  DATABASE_ERROR = 4000,
  DATABASE_CONNECTION_ERROR = 4001,
  DATABASE_QUERY_ERROR = 4002,
  DATABASE_TRANSACTION_ERROR = 4003,

  // 缓存错误 (5000-5999)
  CACHE_ERROR = 5000,
  CACHE_NOT_FOUND = 5001,
  CACHE_WRITE_ERROR = 5002,

  // 数据错误 (6000-6999)
  DATA_NOT_FOUND = 6000,
  DATA_INVALID = 6001,
  DATA_PARSE_ERROR = 6002,
  CHAT_NOT_FOUND = 6003,
  SEARCH_FAILED = 6004,
  LOAD_FAILED = 6005,
  DOWNLOAD_FAILED = 6006,

  // 权限错误 (7000-7999)
  PERMISSION_DENIED = 7000,
  PERMISSION_NOT_GRANTED = 7001,

  // 验证错误 (8000-8999)
  VALIDATION_ERROR = 8000,
  VALIDATION_FAILED = 8001,

  // 存储错误 (9000-9999)
  STORAGE_ERROR = 9000,
  STORAGE_FULL = 9001,
  STORAGE_ACCESS_ERROR = 9002,
  STORAGE_NOT_AVAILABLE = 9003,
  STORAGE_IO_ERROR = 9004,
  STORAGE_ACCESS_DENIED = 9005,
  STORAGE_KEY_NOT_FOUND = 9006
}
